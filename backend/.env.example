# TiDB Cloud (MySQL compatible)
DATABASE_URL=mysql+pymysql://username:password@gateway.tidbcloud.com:4000/emergency_vault?ssl_verify_cert=true&ssl_verify_identity=true

# JWT
SECRET_KEY=replace_with_64_char_random_string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# CORS — add your Vercel frontend URL
CORS_ORIGINS=["http://localhost:5173","https://your-app.vercel.app"]
